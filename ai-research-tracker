// --- SECURITY-HARDENED CONFIGURATION ---
// Store these in Apps Script → Project Settings → Script Properties
const GEMINI_API_KEY = PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
const TARGET_EMAIL_ADDRESS = PropertiesService.getScriptProperties().getProperty('TARGET_EMAIL');

const SEARCH_QUERY = 'from:publish.ssrn.com is:unread';
const GEMINI_MODEL = 'gemini-3-flash';

// --- UTILITY: HTML ESCAPING ---
function escapeHtml(text) {
  if (!text) return '';
  return text.replace(/[&<>"']/g, function (match) {
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    };
    return map[match];
  });
}

// --- MAIN FUNCTION ---
function runDailySSRNTracker() {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet()?.getActiveSheet() || null;

    const threads = GmailApp.search(SEARCH_QUERY, 0, 15);
    if (threads.length === 0) return;

    let evaluatedPapers = [];

    for (let i = 0; i < threads.length; i++) {
      const messages = threads[i].getMessages();
      const latestMessage = messages[messages.length - 1];

      const subject = latestMessage.getSubject();
      let body = latestMessage.getPlainBody();

      // Minimize data sent externally
      body = body.substring(0, 5000);

      const link = threads[i].getPermalink();

      const paperText = `Title: ${subject}\nAbstract: ${body}`;
      const evaluation = evaluateSinglePaper(paperText);

      if (evaluation && evaluation.category !== "Skip") {
        evaluation.link = link;
        evaluation.title = evaluation.title || subject;
        evaluatedPapers.push(evaluation);
      }

      threads[i].markRead();
    }

    if (evaluatedPapers.length === 0) return;

    const today = new Date();

    let emailHtml = '<div style="font-family: Arial, sans-serif; line-height: 1.6; max-width: 800px;">';
    emailHtml += '<h2>Daily Research Briefing</h2>';

    let topPicksHtml = '<h3>Top picks of the day</h3><ul>';
    let worthLookHtml = '<h3>Worth a look</h3><ul>';

    let hasTopPicks = false;
    let hasWorthLook = false;

    evaluatedPapers.forEach(paper => {
      const title = escapeHtml(paper.title);
      const source = escapeHtml(paper.source || 'Unknown Source');
      const hook = escapeHtml(paper.hook || '');
      const summary = escapeHtml(paper.summary || '');
      const relevance = escapeHtml(paper.relevance || '');
      const link = paper.link;

      if (sheet) {
        sheet.appendRow([
          today,
          paper.category,
          `${title} (${source})`,
          `${hook}\n\n${summary}`,
          relevance,
          link
        ]);
      }

      const itemHtml = `
        <li style="margin-bottom: 12px;">
          <strong><a href="${link}">${title}</a></strong> (${source})<br>
          <em>${hook}</em><br>
          ${summary}<br>
          <strong>${paper.category === 'Top Pick' ? 'Why it matters:' : 'Angle:'}</strong> ${relevance}
        </li>`;

      if (paper.category === 'Top Pick') {
        hasTopPicks = true;
        topPicksHtml += itemHtml;
      } else if (paper.category === 'Worth a Look') {
        hasWorthLook = true;
        worthLookHtml += itemHtml;
      }
    });

    if (hasTopPicks) emailHtml += topPicksHtml + '</ul>';
    if (hasWorthLook) emailHtml += worthLookHtml + '</ul>';

    emailHtml += '</div>';

    MailApp.sendEmail({
      to: TARGET_EMAIL_ADDRESS,
      subject: 'Daily Research Briefing',
      htmlBody: emailHtml
    });

  } catch (error) {
    MailApp.sendEmail({
      to: TARGET_EMAIL_ADDRESS,
      subject: 'Error: Research Script Failed',
      body: 'The script failed. Check Apps Script logs for details.'
    });
  }
}

// --- AI EVALUATION FUNCTION (FULL PROMPT RESTORED) ---
function evaluateSinglePaper(paperData) {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${GEMINI_MODEL}:generateContent?key=${GEMINI_API_KEY}`;

  const systemInstruction = `You are a research assistant for an energy economist. Your task is to review papers and posts released in the past 24 hours and extract the highest-signal items.

THE RESEARCHER
Works on:
- Business and firm strategy
- Innovation and energy transition
- Finance and financial economics

Primary additional research areas:
- Innovation and technology strategy of firms (clean tech adoption, R&D, diffusion, industrial policy, strategic behavior of energy and tech firms, platform/business model innovation in energy systems)
- Business strategy and economics, mostly topics published in Strategic Management Journal and Journal of International Business Studies and similar journals
- Corporate finance and financial analysis, especially related to energy markets

RULES
- Prioritize mechanism over description. Explain how and why results arise.
- Be specific and quantitative where possible.
- Calibrate importance strictly. Most items are not top picks.
- Do not infer details that are not stated.

OUTPUT FORMAT
You MUST respond ONLY with a valid JSON object.

Top Pick:
{
  "category": "Top Pick", 
  "title": "Exact Title of Paper",
  "source": "Journal or source name",
  "hook": "One-line 'why this matters' hook.",
  "summary": "2–3 sentences summarizing the core contribution.",
  "relevance": "Why it matters for my research."
}

Worth a Look:
{
  "category": "Worth a Look",
  "title": "Paper Title",
  "source": "Journal or source name",
  "hook": "One sentence summary.",
  "summary": "1-2 sentences summarizing the core contribution",
  "relevance": "Indicate the angle."
}

Otherwise:
{
  "category": "Skip"
}`;

  const payload = {
    contents: [{ parts: [{ text: systemInstruction + "\n\nHERE IS THE PAPER TO EVALUATE:\n" + paperData }] }],
    generationConfig: { responseMimeType: "application/json" }
  };

  const options = {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };

  const maxRetries = 3;
  let attempt = 0;

  while (attempt < maxRetries) {
    try {
      const response = UrlFetchApp.fetch(url, options);
      const code = response.getResponseCode();

      if (code === 200) {
        const data = JSON.parse(response.getContentText());
        const text = data?.candidates?.[0]?.content?.parts?.[0]?.text;
        if (!text) return { category: 'Skip' };

        return JSON.parse(text.trim());
      }

      if (code === 429 || code >= 500) {
        Utilities.sleep(Math.pow(2, attempt) * 1000);
        attempt++;
      } else {
        return { category: 'Skip' };
      }

    } catch (e) {
      Utilities.sleep(Math.pow(2, attempt) * 1000);
      attempt++;
    }
  }

  return { category: 'Skip' };
}
